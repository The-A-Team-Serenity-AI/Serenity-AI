# Google AI API Key (Primary)
VITE_GOOGLE_AI_API_KEY=your_primary_gemini_api_key_here

# Fallback Gemini API Keys for Rate Limits (comma separated)
VITE_FALLBACK_API_KEYS=your_fallback_key_1,your_fallback_key_2,your_fallback_key_3

# Mascot (Amy) dedicated API Key — uses Gemini 3.1 Flash Lite for chat
MASCOT_GEMINI_API_KEY=your_mascot_gemini_api_key_here

# Live API Key — Gemini 2.5 Flash Native Audio Dialog (WebSocket voice mode)
LIVE_API_KEY=your_gemini_live_api_key_here

# Google OAuth Client ID
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# MongoDB Configuration
# Create your database at: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/database_name

# Server Configuration
PORT=5000

# Google OAuth Client Secret (Backend only - DO NOT expose to frontend)
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
